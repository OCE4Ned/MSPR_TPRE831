# Copier ce fichier en ml/.env et renseigner les valeurs.
# ml/.env est ignore par git (ne jamais committer les identifiants).

MLFLOW_TRACKING_URI=https://mlflow.ecluse.cloud/
MLFLOW_TRACKING_USERNAME=...
MLFLOW_TRACKING_PASSWORD=...

# Certificat serveur a chaine CA non conforme -> verification TLS desactivee.
MLFLOW_TRACKING_INSECURE_TLS=true
