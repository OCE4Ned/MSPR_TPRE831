REGISTRY=hub.ecluse.cloud

# Base de donnees PostgreSQL
POSTGRES_USER=mspr
POSTGRES_PASSWORD=mspr
POSTGRES_DB=industrial_dw
POSTGRES_PORT=
# Hote = nom du service compose (postgres) pour le backend conteneurise.
# En dev local (uvicorn), utiliser plutot localhost.
DATABASE_URL=postgresql+psycopg://{POSTGRES_USER}:{POSTGRES_PASSWORD}@postgres:5432/{POSTGRES_DB}

# ETL Compose
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_LISTENERS=PLAINTEXT://:9092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=industrial.raw
SOURCE_DIRS=/app/data/raw,/app/data/processed/business
SOURCE_GLOB=*.csv

MACHINE_MAPPING_PATH=/app/data/processed/business/machine_mapping.csv
PARTS_PATH=/app/data/processed/business/parts.csv
SEND_INTERVAL_SECONDS=2
MAX_EVENTS=0

KAFKA_GROUP_ID=datalake-writer
DATALAKE_RAW_DIR=/app/data/datalake/raw
MAX_IDLE_SECONDS=20

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://mspr:mspr@postgres:5432/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=mspr-airflow-shared-secret
AIRFLOW_CONN_INDUSTRIAL_POSTGRES=postgres://mspr:mspr@postgres:5432/industrial_dw
AIRFLOW_VAR_DATALAKE_RAW_DIR=/opt/airflow/data/datalake/raw
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_VAR_POSTGRES_CONN_ID=industrial_dw
ETL_WRITER_PASSWORD=etl_writer_password

# Grafana
GRAFANA_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://grafana.ecluse.cloud

PUBLIC_API_BASE_URL=https://api.ecluse.cloud

#MLFLOW
MLFLOW_TRACKING_URI=https://mlflow.ecluse.cloud
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MODEL_NAME=mecha-supervision
MODEL_STAGE=development

# API IA
ENV=development
API_KEY=your_api_key_here
LOG_LEVEL=INFO