# Ports
APP_METIER_PORT=
SERVER_METIER_PORT=
API_IA_PORT=
DOCKER_REGISTRY=hub.ecluse.cloud

# Base de donnees PostgreSQL
POSTGRES_USER=mecha
POSTGRES_PASSWORD=mecha
POSTGRES_DB=mecha
POSTGRES_PORT=5432
# Hote = nom du service compose (postgres) pour le backend conteneurise.
# En dev local (uvicorn), utiliser plutot localhost.
DATABASE_URL=postgresql+psycopg://mecha:mecha@postgres:5432/mecha

# Grafana
GRAFANA_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://grafana.ecluse.cloud