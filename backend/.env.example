# Connexion au data-warehouse PostgreSQL (industrial_dw, schema gold).
# Identifiants definis dans deployments/compose.etl.yml.
#
# En local (uvicorn) : hote = localhost.
# Dans Docker Compose : remplacer localhost par le nom du service (postgres).
DATABASE_URL=postgresql+psycopg://mspr:mspr@localhost:5432/industrial_dw

# API IA MECHA (predictions etat 7j / RUL). Cle transmise via header X-API-Key.
# Le certificat ecluse.cloud est auto-signe -> IA_VERIFY_SSL=false en local.
IA_API_BASE_URL=https://api-ia.ecluse.cloud
IA_API_KEY=mecha_api_key
IA_VERIFY_SSL=false
IA_TIMEOUT=10
